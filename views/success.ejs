<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LuvToWatch - Ticket Successful</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel = "stylesheet" type = "text/css" href = "/stylesheets/success.css">
    <link rel = "icon" type = "image/icon" href = "/images/tickets.png">
</head>
<body>
    <!-- Animated background circles -->
    <div class="bg-decoration">
        <div class="circle circle-1"></div>
        <div class="circle circle-2"></div>
        <div class="circle circle-3"></div>
    </div>

    <!-- Brand logo -->
    <div class="brand">
        <i class="fas fa-crown"></i>
        <span>LuvToWatch</span>
    </div>

    <!-- Main success card -->
    <div class="success-card">
        <div class="icon-container">
            <div class="success-icon">
                <i class="fas fa-check"></i>
            </div>
            <div class="ripple"></div>
            <div class="ripple ripple-2"></div>
        </div>

        <h1 class="success-title">Ticket Booked!</h1>
        
        <p class="success-message">Your movie ticket has been successfully sent to</p>
        
        <div class="email-highlight" id="userEmail">
            <i class="fas fa-envelope"></i>
            <span id="emailDisplay"><%= recieveremail %></span>
        </div>

        <div class="ticket-info">
            <div class="info-badge">
                <i class="fas fa-film"></i>
                <span>Digital Ticket</span>
            </div>
            <div class="info-badge">
                <i class="fas fa-qrcode"></i>
                <span>QR Code Attached</span>
            </div>
        </div>

        <a href = "http://localhost:5173">
        <button class="home-btn" onclick="goToHome()">
            <i class="fas fa-home"></i>
            Go to Home
            <i class="fas fa-arrow-right"></i>
        </button>
        </a>
    </div>

    <!-- Confetti animation -->
    <div id="confetti-container"></div>
    <script src = "/javascripts/success.js"></script>
</body>
</html>